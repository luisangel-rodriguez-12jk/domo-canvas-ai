{
  "name": "domo-canvas-ai",
  "version": "0.1.0",
  "private": false,
  "description": "Domo Canvas AI - editor desktop Windows para diseños de playeras con canvas, capas PNG, pinceles e IA.",
  "author": "Domo Streetwear",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder --win nsis portable",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "release:configure": "node scripts/set-github-publish.mjs",
    "release:win": "npm run build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron-updater": "^6.8.3",
    "konva": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-konva": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "vite-plugin-electron": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "mx.domo.canvasai",
    "productName": "Domo Canvas AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Domo-Canvas-AI-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "luisangel-rodriguez-12jk",
        "repo": "domo-canvas-ai",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/luisangel-rodriguez-12jk/domo-canvas-ai.git"
  }
}
